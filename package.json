{
  "name": "kitchenhood",
  "version": "1.0.0",
  "description": "Kitchen Hood Service & Repair - Full Stack Project",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/tailwind.css",
    "dev": "concurrently \"nodemon server.js\" \"npx tailwindcss -i ./public/css/input.css -o ./public/css/tailwind.css --watch\""
  },
  "keywords": [
    "kitchen",
    "hood",
    "service",
    "repair",
    "cleaning"
  ],
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.3",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "concurrently": "^10.0.3",
    "nodemon": "^3.0.1",
    "tailwindcss": "^3.4.17"
  }
}
